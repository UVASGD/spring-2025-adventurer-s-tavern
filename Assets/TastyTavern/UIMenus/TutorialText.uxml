<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/TastyTavern/UIMenus/MainMenu.uss?fileID=7433441132597879392&amp;guid=5934f4de4984fe5488c6f73f09fa28d0&amp;type=3#MainMenu" />
    <engine:VisualElement name="Root" style="flex-grow: 1; justify-content: center;">
        <engine:VisualElement name="Text" class="menu" style="flex-grow: 1; justify-content: center; align-items: center; align-self: center; width: 80%; max-height: 70%; border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); border-top-width: 4px; border-right-width: 4px; border-bottom-width: 4px; border-left-width: 4px;">
            <engine:Label text="Welcome to Adventurer&apos;s Tavern! You&apos;re a chef in a magical land and you have lots of customers! Patrons from across the province are scrambling to try your varying delicacies consisting of ingredients sourced from the local wildlife, whether they be cuts of meat from towering, fantastical beasts or the tantalizing flesh of small, mysteriously-shaped fruits. Your magical, traveling kitchen-restaurant caravan will travel to different biomes, source local ingredients, and use them to cook delicious dishes to serve to your hungry customers.&#10;&#10;&#10;Your customers&apos; orders appear on the top of the screen, and your cooking station is at the center. Your food will appear there when you cook. To bring food into a cooking station, click on the correct ingredient icon on the right. &#10;&#10;How will you know you&apos;re selecting the right ingredients? There are instructions for what to do on the bottom right!&#10;&#10;Your actions will appear as a column of buttons on your screen. You can perform the action of your current station (such as cutting), trash your order if you mess up, store food once you&apos;re done processing it, transition to the next station, and finally serve your food! &#10;&#10;Have fun!&#10;" name="Instructions" style="height: auto; width: 95%; -unity-text-align: middle-left; max-height: none; min-height: 64%; white-space: normal; font-size: 28px; color: rgb(255, 239, 0); -unity-text-outline-width: 5px; -unity-font-definition: url(&quot;project://database/Assets/TastyTavern/Art/Fonts/Chalkboard-Regular.ttf?fileID=12800000&amp;guid=43cb84234405f2042bb3a98a53562dc8&amp;type=3#Chalkboard-Regular&quot;); -unity-font-style: bold;" />
            <engine:Button text="Close" name="CloseTutorial" style="width: 289px; -unity-text-align: middle-center; white-space: pre; text-overflow: clip; height: auto; min-height: 20%;" />
        </engine:VisualElement>
    </engine:VisualElement>
</engine:UXML>
